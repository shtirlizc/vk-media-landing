---
import { Image } from "astro:assets";
import Title from "../../../components/title.astro";
import decorImg from "../../../assets/images/decor/people.webp";
import defaultPhoto from "./photos/default.png";
import Container from "../../../components/container.astro";

const rows = [8, 7, 6];
const copies = [0, 1, 2, 3];
---

<div class="people">
  <Container>
    <Title id="people-title">
      Главное — люди
      <Image
        slot="image"
        src={decorImg}
        width="134"
        height="135"
        alt=""
        loading="lazy"
      />
    </Title>
  </Container>

  <div class="people__marquee">
    {
      rows.map((itemsCount) => (
        <div class="people__row">
          <div class="people__track">
            {copies.map((copyIndex) => (
              <div
                class="people__group"
                aria-hidden={copyIndex > 0 ? "true" : undefined}
              >
                {Array.from({ length: itemsCount }).map(() => (
                  <button type="button" class="people__photo">
                    <Image
                      src={defaultPhoto}
                      width="250"
                      height="250"
                      alt=""
                      loading="lazy"
                    />
                  </button>
                ))}
              </div>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</div>

<style>
  .people {
    overflow: hidden;
    margin-bottom: 80px;

    & #people-title {
      padding-inline: var(--space16);
    }

    & .people__marquee {
      display: grid;
      margin-top: 42px;
    }

    & .people__row {
      width: 100%;

      &:nth-child(even) .people__track {
        animation-direction: reverse;
      }

      &:hover .people__track,
      &:focus-within .people__track {
        animation-play-state: paused;
      }
    }

    & .people__track {
      display: flex;
      width: max-content;
      will-change: transform;
      animation: people-marquee 45s linear infinite;
    }

    & .people__group {
      display: flex;
      flex-shrink: 0;
      align-items: center;
      gap: 20px;
      padding-right: 20px;
    }

    & .people__photo {
      flex-shrink: 0;
      background: none;
      width: 77px;
      height: 77px;
      border-radius: 50%;
      border: none;
      overflow: hidden;
      cursor: pointer;

      img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      &:hover {
        box-shadow: 0 3px 58px 0 #0062ff;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      & .people__track {
        animation-play-state: paused;
        will-change: auto;
      }
    }

    /* desktop */
    @media (width >= 960px) {
      margin-bottom: 155px;

      & .people__photo {
        width: 200px;
        height: 200px;
      }

      & .people__marquee {
        margin-top: 67px;
      }
    }

    /* widescreen */
    @media (width >= 1200px) {
      margin-bottom: 160px;

      & .people__photo {
        width: 250px;
        height: 250px;
      }

      & .people__marquee {
        margin-top: 67px;
      }
    }
  }

  @keyframes people-marquee {
    to {
      transform: translateX(-25%);
    }
  }
</style>
