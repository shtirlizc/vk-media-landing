---
import Title from "../../../components/title.astro";
import Container from "../../../components/container.astro";

import dzenLogo from "./assets/logos/dzen.svg";
import maxLogo from "./assets/logos/max.svg";
import okLogo from "./assets/logos/ok.svg";
import clipsLogo from "./assets/logos/vk-clips.svg";
import musicLogo from "./assets/logos/vk-music.svg";
import videoLogo from "./assets/logos/vk-video.svg";
import vkLogo from "./assets/logos/vk.svg";

import stars1 from "./assets/decor/stars_1.webp";
import stars2 from "./assets/decor/stars_2.webp";
import stars3 from "./assets/decor/stars_3.webp";
import stars4 from "./assets/decor/stars_4.webp";
import stars5 from "./assets/decor/stars_5.webp";
import stars6 from "./assets/decor/stars_6.webp";
import stars7 from "./assets/decor/stars_7.webp";

type Product = {
  logo: ImageMetadata | string;
  text: string;
  width: number;
  href: string;
};

type RowItem =
  | { type: "product"; product: Product }
  | { type: "decor"; image: ImageMetadata };

const products = {
  video: {
    logo: videoLogo,
    text: "фильмы, трансляции, эксклюзивные проекты",
    width: 183,
    href: "https://vkvideo.ru/",
  },
  music: {
    logo: musicLogo,
    text: "музыка, аудиокниги, подкасты",
    width: 159,
    href: "https://music.vk.com/",
  },
  max: {
    logo: maxLogo,
    text: "мессенджер нового поколения",
    width: 183,
    href: "https://max.ru/",
  },
  clips: {
    logo: clipsLogo,
    text: "миллионы коротких вертикальных видео",
    width: 190,
    href: "https://vkclips.app/",
  },
  vk: {
    logo: vkLogo,
    text: "крупнейшая социальная сеть в России и СНГ",
    width: 190,
    href: "https://vk.com/about",
  },
  ok: {
    logo: okLogo,
    text: "общения и сообщества",
    width: 170,
    href: "https://insideok.ru/info/",
  },
  ok2: {
    logo: okLogo,
    text: "территория общения и увлечений",
    width: 170,
    href: "https://insideok.ru/info/",
  },
  dzen: {
    logo: dzenLogo,
    text: "крупнейшая новостная платформа",
    width: 179,
    href: "https://dzen.ru/about",
  },
} satisfies Record<string, Product>;

const product = (item: Product): RowItem => ({
  type: "product",
  product: item,
});
const decor = (image: ImageMetadata): RowItem => ({ type: "decor", image });

const rows: RowItem[][] = [
  [
    decor(stars1),
    product(products.video),
    decor(stars2),
    product(products.music),
    decor(stars3),
    product(products.max),
  ],
  [
    decor(stars4),
    product(products.clips),
    decor(stars5),
    product(products.vk),
    decor(stars6),
    product(products.ok),
  ],
  [
    decor(stars5),
    product(products.vk),
    decor(stars6),
    product(products.ok2),
    decor(stars7),
    product(products.dzen),
    decor(stars2),
    product(products.music),
  ],
];
---

<section class="products" aria-labelledby="products-title">
  <Container>
    <Title title="h3" id="products-title">
      <span class="products__title">То, что&nbsp;мы&nbsp;создаём</span>
    </Title>
  </Container>

  <div class="products__marquee" data-reveal>
    {
      rows.map((row) => (
        <div class="products__row">
          <div class="products__track">
            {[false, true, true, true].map((isDuplicate) => (
              <div
                class="products__group"
                aria-hidden={isDuplicate ? "true" : undefined}
              >
                {row.map((item) =>
                  item.type === "decor" ? (
                    <img
                      class="products__decor"
                      src={item.image.src}
                      alt=""
                      width="72"
                      height="72"
                      loading="lazy"
                    />
                  ) : (
                    <a
                      class="products__card"
                      href={item.product.href}
                      target="_blank"
                      rel="noreferrer"
                      tabindex={isDuplicate ? "-1" : undefined}
                    >
                      <img
                        class="products__logo"
                        src={
                          typeof item.product.logo === "string"
                            ? item.product.logo
                            : item.product.logo.src
                        }
                        alt=""
                        width="40"
                        height="40"
                        loading="lazy"
                      />
                      <span style={`--product-width: ${item.product.width}px`}>
                        {item.product.text}
                      </span>
                    </a>
                  ),
                )}
              </div>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  .products {
    overflow: hidden;

    /* desktop */
    @media (width >= 960px) {
      padding-bottom: 80px;
    }

    /* widescreen */
    @media (width >= 1200px) {
      margin-top: -36px;
    }

    /* fullhd */
    @media (width >= 1600px) {
      margin-top: 0;
    }
  }

  & .products__title {
    letter-spacing: -1px;

    /* desktop */
    @media (width >= 960px) {
      letter-spacing: -1.5px;
    }

    /* widescreen */
    @media (width >= 1200px) {
      letter-spacing: -2px;
    }

    /* fullhd */
    @media (width >= 1600px) {
      letter-spacing: 0;
      font-size: 72px;
    }
  }

  .products__marquee {
    display: grid;
    gap: var(--space16);
    margin-top: 38px;

    /* desktop */
    @media (width >= 960px) {
      gap: var(--space24);
    }

    /* widescreen */
    @media (width >= 1200px) {
      margin-top: 64px;
    }

    /* fullhd */
    @media (width >= 1600px) {
      margin-top: 100px;
    }
  }

  .products__row {
    width: 100%;
  }

  .products__track {
    display: flex;
    width: max-content;
    will-change: transform;
    animation: products-marquee 45s linear infinite;
  }

  .products__row:nth-child(even) .products__track {
    animation-direction: reverse;
  }

  .products__row:hover .products__track,
  .products__row:focus-within .products__track {
    animation-play-state: paused;
  }

  .products__group {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    gap: var(--space8);
    padding-right: var(--space8);

    /* desktop */
    @media (width >= 960px) {
      gap: var(--space24);
      padding-right: var(--space24);
    }
  }

  .products__card {
    font-family: var(--font-secondary), sans-serif;
    line-height: 1.1;
    display: flex;
    flex-shrink: 0;
    align-items: center;
    gap: 20px;
    min-height: 72px;
    padding: var(--space16);
    border-radius: 20px;
    background: #101010;
    font-size: 16px;
    font-weight: 500;
    text-transform: lowercase;
    color: var(--color-text-primary);
    box-shadow: 0 3px 58.6px 0 transparent;
    transition: box-shadow var(--transition-long) ease;

    /* desktop */
    @media (width >= 960px) {
      font-weight: 500;
      font-size: 24px;
      padding: var(--space24);
      min-width: 450px;
    }

    /* fullhd */
    @media (width >= 1600px) {
      font-size: 32px;
      min-width: 550px;
      gap: 36px;
    }

    @media (hover: hover) {
      &:hover {
        box-shadow: 0 3px 58px 0 #0062ff;
      }
    }
  }

  .products__card:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: -4px;
  }

  .products__card span {
    width: var(--product-width);
    flex: 1;
  }

  .products__logo {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    object-fit: contain;

    /* desktop */
    @media (width >= 960px) {
      width: 70px;
      height: 70px;
    }

    /* fullhd */
    @media (width >= 1600px) {
      width: 90px;
      height: 90px;
    }
  }

  .products__decor {
    width: 72px;
    height: 72px;
    flex-shrink: 0;
    object-fit: contain;

    /* desktop */
    @media (width >= 960px) {
      width: 116px;
      height: 116px;
    }

    /* fullhd */
    @media (width >= 1600px) {
      width: 170px;
      height: 170px;
    }
  }

  @keyframes products-marquee {
    to {
      transform: translateX(-25%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .products__track {
      animation-play-state: paused;
      will-change: auto;
    }
  }
</style>
