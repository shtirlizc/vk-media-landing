---
import { Image } from "astro:assets";
import decorImg from "./assets/decor.png";
import videoPoster from "./assets/buisness-video-preview.jpg";
import Container from "../../../components/container.astro";
---

<section class="hero" aria-labelledby="hero">
  <Container>
    <div class="hero__copy">
      <p class="hero__eyebrow">Бизнес-группа</p>

      <h1 class="hero__title">«Социальные платформы и медиаконтент»</h1>

      <p class="hero__description">
        Мы — большая часть VK. Создаём и развиваем ключевые соцсети,
        медиасервисы и развлекательные проекты.
      </p>
    </div>

    <Image class="hero__decor" src={decorImg} width="500" height="279" alt="" />

    <div class="hero__media">
      <video
        class="hero__video"
        src="https://storage.yandexcloud.net/team-hh-email/vk-media-landing/hero.mp4"
        title="Видео о бизнес-группе"
        preload="metadata"
        poster={videoPoster.src}
        playsinline
      >
      </video>

      <button class="hero__play" type="button" aria-label="Запустить видео">
        <img
          src={`${import.meta.env.BASE_URL}play-button.svg`}
          width="22"
          height="26"
          alt="play_button"
        />
      </button>
    </div>
  </Container>
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    display: flex;
    flex-direction: column;
    align-items: center;
    overflow: hidden;
    width: 100%;
    background: var(--color-bg-main);
    padding-block: var(--space48) var(--space32);

    &::before {
      content: "";
      position: absolute;
      top: 140px;
      left: 50%;
      transform: translate(-50%);
      width: 19627px;
      height: 19761px;
      background: radial-gradient(
        93.7% 32.19% at 50.49% 25.96%,
        rgba(1, 56, 146, 0) 78.75%,
        #f3f8ff 79.93%,
        #f3f7ff 80.61%,
        #d7e6ff 95.9%
      );
      border: 46px solid #0162ff;
      filter: blur(60px);
    }


    &::before {
      content: "";
      position: absolute;
      top: 140px;
      left: 50%;
      transform: translate(-50%);
      width: 19627px;
      height: 19761px;
      background: radial-gradient(
        93.7% 32.19% at 50.49% 25.96%,
        rgba(1, 56, 146, 0) 78.75%,
        #f3f8ff 79.93%,
        #f3f7ff 80.61%,
        #d7e6ff 95.9%
      );
      border: 46px solid #0162ff;
      filter: blur(60px);
    }

    & .hero__copy {
      position: relative;
      z-index: 2;
      width: 100%;
      text-align: center;
    }

    & .hero__eyebrow {
      margin-top: var(--space48);
      margin-bottom: var(--space20);
      font-size: 14px;
      font-weight: 400;
      line-height: 1;
    }

    & .hero__title {
      font-family: var(--font-primary), sans-serif;
      font-size: 25px;
      font-weight: 700;
      line-height: 86%;
      letter-spacing: -0.02em;
      text-transform: lowercase;
    }

    & .hero__description {
      max-width: 328px;
      margin: var(--space20) auto;
      font-size: 17px;
      font-weight: 400;
      line-height: 94%;
      letter-spacing: -0.025em;
    }

    & .hero__decor {
      z-index: 1;
      align-self: flex-end;
      width: 280px;
      max-width: none;
      height: auto;
      margin: 0;
      transform: translateX(133px) rotate(-5deg);
    }

    & .hero__media {
      position: relative;
      z-index: 3;
      width: 100%;
      margin-top: -80px;
      aspect-ratio: 328 / 211;
      overflow: hidden;
      border-radius: var(--border-radius12);
      background-color: #071b49;
    }

    & .hero__video {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;

    & .hero__play {
      position: absolute;
      inset: 50% auto auto 50%;
      display: grid;
      place-items: center;
      width: 48px;
      height: 48px;
      padding: 0;
      border: 0;
      background: transparent;
      color: var(--color-text-primary);
      cursor: pointer;
      transform: translate(-50%, -50%);
      transition:
        transform var(--transition),
        opacity var(--transition);
    }

    & .hero__play:hover {
      transform: translate(-50%, -50%) scale(1.06);
    }

    & .hero__play:focus-visible {
      outline: 2px solid var(--color-text-primary);
      outline-offset: 4px;
    }

    & .hero__play img {
      display: block;
      width: 26px;
      height: 31px;
    }

    & .hero__media.is-playing .hero__play {
      visibility: hidden;
      opacity: 0;
      pointer-events: none;
    }
  }

  /* desktop */
  @media (width >= 991px) {
    .hero {
      &::before {
        top: -96px;
        width: max(100%, 1600px);
        height: 650px;
        filter: blur(42px);
      }

      & .hero__eyebrow {
        margin-bottom: var(--space40);
        font-size: 16px;
      }

      & .hero__title {
        font-size: 36px;
        line-height: 83%;
      }

      & .hero__description {
        max-width: none;
        margin-top: var(--space44);
        font-size: 20px;
        line-height: 82%;
      }

      & .hero__media {
        aspect-ratio: 880 / 450;
        margin-top: -110px;
        border-radius: var(--border-radius16);
      }
    }
  }

  /* widescreen */
  @media (width >= 1200px) {
    .hero {
      & .hero__copy,
      & .hero__media {
        max-width: var(--container);
      }

      & .hero__title {
        font-size: 44px;
      }

      & .hero__description {
        font-size: 24px;
      }

      & .hero__media {
        aspect-ratio: 1120 / 640;
      }
    }
  }
</style>

<script>
  const media = document.querySelector<HTMLElement>(".hero__media");
  const video = media?.querySelector<HTMLVideoElement>(".hero__video");
  const playButton = media?.querySelector<HTMLButtonElement>(".hero__play");

  playButton?.addEventListener("click", async () => {
    if (!video) return;

    try {
      await video.play();
      video.controls = true;
    } catch {
      media?.classList.remove("is-playing");
    }
  });

  video?.addEventListener("play", () => media?.classList.add("is-playing"));
  video?.addEventListener("pause", () => media?.classList.remove("is-playing"));
  video?.addEventListener("ended", () => media?.classList.remove("is-playing"));
</script>
