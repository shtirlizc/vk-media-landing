---
import Title from "../../../components/title.astro";
import Container from "../../../components/container.astro";
import card1Img from "./assets/1.webp";
import card2Img from "./assets/2.webp";
import card3Img from "./assets/3.webp";
import card4Img from "./assets/4.webp";

const cards = [
  {
    image: card1Img,
    title:
      "Трансляции в каналах MAX реализованы через интеграцию с платформой VK Видео",
  },
  {
    image: card2Img,
    title:
      "Единая панель VK Games для публикации и управления играми для ВКонтакте и ОК",
    isImageCompact: true,
  },
  {
    image: card3Img,
    title: "Интеграция новостей Дзена в ОК",
    isImageCompact: true,
  },
  {
    image: card4Img,
    title:
      "VK ID — единый сервис авторизации в OK, ВКонтакте и на других платформах",
    isImageCompact: true,
  },
];
---

<section class="group" aria-labelledby="group-title">
  <Container>
    <div class="group__pin">
      <Title title="h3" id="group-title">
        <span class="group__title">
          Как мы усиляем друг друга<br />внутри <span>бизнес-группы</span>
        </span>
      </Title>

      <p class="group__description" data-reveal>
        Все команды работают над своими продуктами в рамках одной
        медиастратегии. Вместе развиваем кросс-платформенные сценарии и делимся
        инфраструктурой для ускорения роста каждого продукта.
      </p>

      <div class="group__viewport" data-reveal>
        <div class="group__deck" data-group-deck>
          {
            cards.map((card, index) => (
              <article
                class:list={["group__card", index === 0 && "is-active"]}
                data-group-card
              >
                <p>{card.title}</p>
                <div
                  class:list={[
                    "group__bg",
                    card.isImageCompact && "group__bg--compact",
                  ]}
                  style={`background-image: url("${card.image.src}")`}
                />
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </Container>
</section>

<style>
  .group {
    overflow: clip;
    margin-top: calc(-0.5 * var(--section-gap));
    margin-bottom: calc(-1 * var(--section-gap));
    max-width: 100vw;
  }

  .group__pin {
    min-height: 100svh;
    display: grid;
    align-content: center;
    padding-top: calc(2 * var(--space40));
    padding-bottom: var(--space40);
  }

  .group__title {
    line-height: 110%;

    /* desktop */
    @media (width >= 960px) {
      letter-spacing: -1.5px;
      line-height: 100%;
    }

    /* widescreen */
    @media (width >= 1200px) {
      letter-spacing: -2px;
      line-height: 90%;
    }

    span {
      white-space: nowrap;
    }
  }

  .group__description {
    margin-top: var(--space24);
    font-family: var(--font-secondary), sans-serif;
    font-weight: 500;
    font-size: 16px;
    line-height: 110%;

    /* desktop */
    @media (width >= 960px) {
      margin-top: var(--space32);
      font-size: 24px;
      max-width: 85%;
    }

    /* widescreen */
    @media (width >= 1200px) {
      font-size: 28px;
    }

    /* fullhd */
    @media (width >= 1600px) {
      margin-top: 42px;
      max-width: 75%;
    }
  }

  .group__viewport {
    --card-width: min(231px, calc(100vw - 96px));
    --card-radius: 20px;
    --deck-height: calc(var(--card-width) * 328 / 231);

    position: relative;
    inline-size: 100%;
    max-inline-size: 100%;
    min-height: var(--deck-height);
    margin-top: var(--space40);

    /* desktop */
    @media (width >= 960px) {
      --card-radius: 32px;

      margin-top: 58px;
    }
  }

  .group__deck {
    position: relative;
    min-height: var(--deck-height);
  }

  .group__card {
    position: absolute;
    top: 0;
    left: 0;
    isolation: isolate;
    overflow: hidden;
    box-shadow: 0 48px 166px 0 #00000040;
    background-color: #202020;
    width: var(--card-width);
    display: flex;
    align-items: flex-end;
    aspect-ratio: 231 / 328;
    padding: 20px 14px 20px 18px;
    letter-spacing: -0.3px;
    border-radius: var(--card-radius);
    color: var(--color-text-primary);
    transform-origin: left center;
    will-change: transform, filter, opacity;
  }

  .group__card::before {
    content: "";
    position: absolute;
    z-index: 0;
    inset: 0;
    pointer-events: none;
    width: 90%;
    height: 90%;
    top: -40%;
    left: -40%;
    border-radius: 50%;
    background: linear-gradient(180deg, #0062ff 0%, #50337f 100%);
    filter: blur(80px);
    opacity: 0;
    transition: opacity var(--transition-long);
  }

  .group__bg {
    content: "";
    position: absolute;
    z-index: 1;
    inset: 0;
    pointer-events: none;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    background-position: top left;
    background-repeat: no-repeat;
    background-size: 304px auto;

    /* desktop */
    @media (width >= 960px) {
      background-size: 404px auto;
    }

    /* widescreen */
    @media (width >= 1200px) {
      background-size: 436px auto;
    }
  }

  .group__bg--compact {
    background-size: 256px auto;

    /* desktop */
    @media (width >= 960px) {
      background-size: 344px auto;
    }

    /* widescreen */
    @media (width >= 1200px) {
      background-size: 380px auto;
    }
  }

  .group__card.is-active::before {
    opacity: 1;
  }

  .group__card p {
    z-index: 2;
    max-width: 100%;
    font-size: 12px;
    line-height: 1;
  }

  @media (width < 960px) {
    .group__pin {
      height: 100svh;
      min-height: 0;
      grid-template-rows: auto auto minmax(0, 1fr);
      align-content: stretch;
      padding-top: calc(var(--header) + var(--space16));
      padding-bottom: var(--space20);
    }

    .group__viewport {
      min-height: 0;
      display: grid;
      align-items: end;
      margin-top: var(--space24);
    }

    .group__deck {
      min-height: 0;
      height: 100%;
    }

    .group__card {
      width: auto;
      max-width: 100%;
      height: min(var(--deck-height), 100%);
    }
  }

  @media (width >= 960px) {
    .group__pin {
      padding-top: 128px;
      padding-bottom: 64px;
      margin: 0;
    }

    .group__viewport {
      --card-width: 423px;
      --card-height: 391px;
      --deck-height: var(--card-height);

      margin-top: 58px;

      /* widescreen */
      @media (width >= 1200px) {
        margin-top: 80px;
      }
    }

    .group__card {
      height: var(--card-height);
      aspect-ratio: auto;
      padding: 30px 24px;
      letter-spacing: -0.5px;
      border-radius: 32px;
    }

    .group__card p {
      right: var(--space24);
      bottom: var(--space24);
      left: var(--space24);
      font-size: 12px;

      /* desktop */
      @media (width >= 960px) {
        font-size: 18px;
      }

      /* widescreen */
      @media (width >= 1200px) {
        font-size: 20px;
      }

      /* fullhd */
      @media (width >= 1600px) {
        font-size: 24px;
      }
    }
  }

  @media (width >= 1200px) {
    .group__viewport {
      --card-width: 462px;
      --card-height: 428px;
    }

    .group__card {
      border-radius: 32px;
    }
  }

  /* fullhd */
  @media (width >= 1600px) {
    .group__card {
      padding: 30px 37px 34px 24px;
    }
  }

  @media (1200px <= width < 1600px) {
    .group__viewport {
      width: calc(100% + var(--space8));
      margin-left: calc(-1 * var(--space8));
    }
  }

  @media (width >= 1600px) {
    .group__viewport {
      --card-width: 485px;
      --card-height: 450px;
      --deck-height: var(--card-height);
    }

    .group__card {
      border-radius: 33.63px;
    }
  }
</style>
