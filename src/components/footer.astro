---
import { navigation } from "../data/navigation.ts";
---

<footer class="footer">
  <div class="footer__content">
    <nav class="footer__nav" aria-label="Навигация в подвале">
      <ul>
        {
          navigation.map(({ label, href }) => (
            <li>
              <a href={`#${href}`}>{label}</a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</footer>

<style>
  .footer {
    padding: 120px var(--space16) var(--space40);

    & .footer__content {
      max-width: 430px;
      width: 100%;
      margin-inline: auto;

      /* widescreen */
      @media (width >= 1200px) {
        max-width: 550px;
      }
    }

    & .footer__nav {
      ul {
        list-style: none;
        padding: 0;
        display: flex;
        justify-content: space-between;
        align-items: center;

        a {
          opacity: 0.5;
          font-family: var(--font-secondary), sans-serif;
          font-size: 12px;
          line-height: 83%;
          text-transform: lowercase;
          color: var(--color-text-primary);
          transition: opacity var(--transition);

          &:hover {
            opacity: 1;
          }
        }
      }
    }
  }
</style>
