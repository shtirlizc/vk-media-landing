---
import { Image } from "astro:assets";
import decorImg from "./assets/decor.webp";
import videoPoster from "./assets/buisness-video-preview.webp";
import PlayButton from "../../../assets/images/play-button.svg";
import PauseButton from "../../../assets/images/pause-button.svg";
import Container from "../../../components/container.astro";
---

<section class="hero" aria-labelledby="hero">
  <Container>
    <div class="hero__copy">
      <p class="hero__eyebrow">Бизнес-группа</p>

      <h1 class="hero__title">«Социальные платформы и медиаконтент»</h1>

      <p class="hero__description">
        Мы — большая часть VK. Создаём и развиваем ключевые соцсети,
        медиасервисы и развлекательные проекты.
      </p>
    </div>
  </Container>

  <Image
    class="hero__decor"
    src={decorImg}
    width={1494}
    height={1465}
    widths={[291, 582, 619, 747, 1238, 1494]}
    sizes="(min-width: 1200px) 747px, (min-width: 960px) 619px, 291px"
    alt=""
  />

  <Container>
    <div class="hero__media" data-video-player>
      <video
        class="hero__video"
        data-video-player-video
        src="https://storage.yandexcloud.net/team-hh-email/vk-media-landing/hero.mp4"
        title="Видео о бизнес-группе"
        preload="metadata"
        poster={videoPoster.src}
        playsinline
      >
      </video>

      <button
        class="hero__playback"
        type="button"
        aria-label="Запустить видео"
        data-video-player-playback
      >
        <span class="hero__play-icon"><PlayButton /></span>
        <span class="hero__pause-icon"><PauseButton /></span>
      </button>
    </div>
  </Container>
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    display: flex;
    flex-direction: column;
    align-items: center;
    overflow: hidden;
    width: 100%;
    padding: 50px 0 5px;

    /* desktop */
    @media (width >= 960px) {
      padding: 65px 0 15px;
    }

    /* widescreen */
    @media (width >= 1200px) {
      padding: 125px 0 15px;
    }

    &::before {
      content: "";
      position: absolute;
      top: 160px;
      left: 50%;
      transform: translate(-50%);
      width: 29627px;
      height: 29761px;
      background: radial-gradient(
        93.7% 32.19% at 50.49% 25.96%,
        rgba(1, 56, 146, 0) 78.75%,
        #f3f8ff 79.93%,
        #f3f7ff 80.61%,
        #d7e6ff 95.9%
      );
      border: 150px solid #0162ff;
      filter: blur(50px);
    }

    & .hero__copy {
      position: relative;
      z-index: 2;
      width: 100%;
      text-align: center;
    }

    & .hero__eyebrow {
      margin-bottom: var(--space20);
      font-size: 16px;
      line-height: 1em;
      text-align: center;
    }

    & .hero__title {
      font-size: 24px;
      font-weight: 700;
      line-height: 93%;
      text-align: center;
      text-transform: lowercase;
    }

    & .hero__description {
      margin: var(--space20) auto 0;
      font-size: 16px;
      line-height: 100%;
      text-align: center;
      letter-spacing: -0.3px;
    }

    & .hero__decor {
      align-self: flex-end;
      width: 291px;
      height: auto;
      z-index: 1;
      margin-top: -20px;
    }

    & .hero__media {
      position: relative;
      z-index: 3;
      margin-top: -170px;
      margin-inline: auto;
      aspect-ratio: 328 / 211;
      clip-path: inset(0 round 20px);
    }

    & .hero__video {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    & .hero__playback {
      position: absolute;
      inset: 0;
      display: grid;
      place-items: center;
      width: 48px;
      height: 48px;
      margin: auto;
      padding: 0;
      border: 0;
      background: transparent;
      cursor: pointer;
      color: var(--color-text-primary);
      transition:
        color var(--transition),
        opacity var(--transition);
    }

    & .hero__playback:hover {
      color: var(--color-primary);
    }

    & .hero__playback:focus-visible {
      outline: 2px solid var(--color-text-primary);
      outline-offset: 4px;
    }

    & .hero__pause-icon {
      display: none;
    }

    & .hero__media[data-playing] .hero__play-icon {
      display: none;
    }

    & .hero__media[data-playing] .hero__pause-icon {
      display: block;
    }

    @media (hover: hover) {
      &
        .hero__media[data-playing]:not(:hover)
        .hero__playback:not(:focus-visible) {
        opacity: 0;
      }
    }
  }

  /* desktop */
  @media (width >= 960px) {
    .hero {
      &::before {
        top: 200px;
      }

      & .hero__eyebrow {
        margin-bottom: var(--space32);
        font-size: 24px;
      }

      & .hero__title {
        font-size: 44px;
        line-height: 93%;
      }

      & .hero__description {
        margin-top: var(--space28);
        font-size: 24px;
        line-height: 100%;
        max-width: 800px;
        letter-spacing: -1px;
      }

      & .hero__playback svg {
        width: 72px;
        height: 82px;
      }

      & .hero__decor {
        width: 619px;
        margin-top: -92px;
      }

      & .hero__media {
        margin-top: -350px;
        width: calc(100% - 30px);
      }
    }
  }

  /* widescreen */
  @media (width >= 1200px) {
    .hero {
      & .hero__decor {
        width: 747px;
        margin-top: -38px;
      }

      & .hero__eyebrow {
        font-size: 26px;
      }

      & .hero__description {
        font-size: 26px;
      }

      & .hero__title {
        font-size: 60px;
      }

      & .hero__media {
        margin-top: -442px;
        min-width: 1121px;
      }
    }
  }
</style>
