---
import Title from "../../../components/title.astro";
import Container from "../../../components/container.astro";

const cards = [
  {
    title:
      "Видеосообщения в мессенджере MAX работают на базе платформы VK Видео",
  },
  {
    title:
      "Трансляции в каналах MAX реализованы через интеграцию с платформой VK Видео",
  },
  {
    title:
      "Единая панель VK Games для публикации и управления играми для ВКонтакте и ОК",
  },
  {
    title: "Интеграция новостей Дзена в ОК",
  },
  {
    title:
      "VK ID — единый сервис авторизации в OK, ВКонтакте и на других платформах",
  },
];
---

<section class="group" aria-labelledby="group-title">
  <Container>
    <div class="group__pin">
      <Title title="h3" id="group-title">
        Как мы усиливаем друг друга внутри бизнес-группы
      </Title>

      <div class="group__viewport">
        <div class="group__deck" data-group-deck>
          {
            cards.map(({ title }, index) => (
              <article
                class:list={["group__card", index === 0 && "is-active"]}
                data-group-card
              >
                <p>{title}</p>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </Container>
</section>

<style>
  .group {
    overflow: clip;
  }

  .group__pin {
    min-height: 100svh;
    display: grid;
    align-content: center;
    padding-block: var(--space40);
  }

  .group__viewport {
    --card-width: min(231px, calc(100vw - 96px));
    --card-radius: 20px;
    --deck-height: calc(var(--card-width) * 328 / 231);

    position: relative;
    min-height: var(--deck-height);
    margin-top: var(--space32);

    /* desktop */
    @media (width >= 960px) {
      --card-radius: 32px;
    }
  }

  .group__deck {
    position: relative;
    min-height: var(--deck-height);
  }

  .group__card {
    position: absolute;
    top: 0;
    left: 0;
    isolation: isolate;
    overflow: hidden;
    box-shadow: 0 48px 166px 0 #00000040;
    background-color: #202020;
    width: var(--card-width);
    display: flex;
    align-items: flex-end;
    aspect-ratio: 231 / 328;
    padding: var(--space16);
    border-radius: var(--card-radius);
    color: var(--color-text-primary);
    transform-origin: left center;
    will-change: transform, filter, opacity;
  }

  .group__card::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .group__card.is-active::after {
    opacity: 1;
  }

  .group__card p {
    max-width: 100%;
    font-family: var(--font-secondary), sans-serif;
    font-size: 13px;
    font-weight: 500;
    line-height: 0.95;
  }

  @media (width >= 960px) {
    .group__pin {
      padding-block: 64px;
    }

    .group__viewport {
      --card-width: 423px;
      --card-height: 392px;
      --deck-height: var(--card-height);

      margin-top: 48px;
    }

    .group__card {
      aspect-ratio: 423 / 392;
      padding: var(--space24);
      border-radius: var(--border-radius20);
    }

    .group__card p {
      right: var(--space24);
      bottom: var(--space24);
      left: var(--space24);
      font-size: 12px;
      line-height: 100%;

      /* desktop */
      @media (width >= 960px) {
        font-size: 18px;
      }

      /* widescreen */
      @media (width >= 1200px) {
        font-size: 20px;
      }
    }
  }

  @media (width >= 1200px) {
    .group__viewport {
      --card-width: 462px;
      --card-height: 428px;
    }
  }
</style>
