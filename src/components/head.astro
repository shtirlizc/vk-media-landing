---
import { Font } from "astro:assets";

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
const siteUrl = Astro.site;
const faviconPath = (path: string) => `${baseUrl}/favicon/${path}`;
const pageUrl = new URL(`${baseUrl}/`, siteUrl).toString();
const shareImageUrl = new URL(`${baseUrl}/cover.jpg`, siteUrl).toString();

const title = "Социальные платформы и медиаконтент | VK";
const description =
  "Бизнес-группа VK, которая создаёт и развивает ключевые соцсети, медиасервисы и развлекательные проекты.";
const keywords =
  "VK, социальные платформы, медиаконтент, ВКонтакте, Одноклассники, VK Видео, VK Музыка, VK Клипы, Дзен, MAX, команда VK";
const imageAlt = "Сцена на мероприятии бизнес-группы VK";
---

<head>
  <meta charset="utf-8" />
  <Font cssVariable="--font-primary" />
  <Font cssVariable="--font-secondary" />
  <link
    rel="icon"
    type="image/png"
    sizes="32x32"
    href={faviconPath("favicon-32x32.png")}
  />
  <link
    rel="icon"
    type="image/png"
    sizes="16x16"
    href={faviconPath("favicon-16x16.png")}
  />
  <link rel="shortcut icon" href={faviconPath("favicon.ico")} />
  <link
    rel="apple-touch-icon"
    sizes="180x180"
    href={faviconPath("apple-touch-icon.png")}
  />

  <meta name="viewport" content="width=device-width" />
  <meta name="color-scheme" content="dark" />
  <meta name="theme-color" content="#01040b" />
  <meta name="title" content={title} />
  <meta name="description" content={description} />
  <meta name="keywords" content={keywords} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={pageUrl} />

  <meta property="og:type" content="website" />
  <meta property="og:locale" content="ru_RU" />
  <meta property="og:site_name" content="VK" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={pageUrl} />
  <meta property="og:image" content={shareImageUrl} />
  <meta property="og:image:secure_url" content={shareImageUrl} />
  <meta property="og:image:type" content="image/jpeg" />
  <meta property="og:image:width" content="561" />
  <meta property="og:image:height" content="348" />
  <meta property="og:image:alt" content={imageAlt} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={shareImageUrl} />
  <meta name="twitter:image:alt" content={imageAlt} />

  <title>{title}</title>
</head>
