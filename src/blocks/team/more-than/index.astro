---
import { Image } from "astro:assets";
import Title from "../../../components/title.astro";
import Container from "../../../components/container.astro";
import PlayButton from "../../../assets/images/play-button.svg";
import slide2Img from "./assets/story-2.webp";
import slide5Img from "./assets/story-5.webp";

interface ISlide {
  title?: string;
}
interface ISlideImage extends ISlide {
  src: ImageMetadata;
}
interface ISlideVideo extends ISlide {
  src: string;
  poster?: string;
}

const checkIsVideo = (item: ISlideImage | ISlideVideo): item is ISlideVideo => {
  return typeof item.src === "string";
};

const slides: (ISlideImage | ISlideVideo)[] = [
  {
    title: "8 марта",
    src: "https://storage.yandexcloud.net/team-hh-email/vk-media-landing/story-1.mp4",
  },
  {
    title: "14 февраля",
    src: slide2Img,
  },
  {
    title: "Drop Store Запуск магазина мерча бизнес-группы",
    src: "https://storage.yandexcloud.net/team-hh-email/vk-media-landing/story-3.mp4",
  },
  {
    title: "ВК Фест 2025",
    src: "https://storage.yandexcloud.net/team-hh-email/vk-media-landing/story-4.mp4",
  },
  {
    title: "Афтепати ВК Фест 2025",
    src: slide5Img,
  },
];
---

<section class="more-than" aria-labelledby="more-than-title">
  <Container>
    <div class="more-than__head">
      <Title title="h3" id="more-than-title">
        Команда — это больше, чем про работу
      </Title>
      <p class="more-than__description">
        Праздники, тимбилдинги, события и даже хобби — нас объединяют не только
        общие задачи
      </p>
    </div>

    <div class="more-than__body">
      <div class="swiper js-more-than-swiper">
        <div class="more-than__pagination">
          {
            slides.map((_, index) => (
              <button
                type="button"
                class:list={[index === 0 && "active"]}
                data-index={index}
              >
                <span>{index}</span>
              </button>
            ))
          }
        </div>

        <div class="swiper-wrapper">
          {
            slides.map((item) => {
              const isVideo = checkIsVideo(item);

              return (
                <div
                  class="swiper-slide"
                  data-media={isVideo ? "video" : "image"}
                >
                  <div class="more-than__slide">
                    <div class="more-than__slide-content">
                      {isVideo ? (
                        <div class="more-than__slide-video">
                          <video
                            src={item.src}
                            poster={item.poster}
                            title={item?.title}
                            preload="metadata"
                          />
                          <button>
                            <PlayButton />
                          </button>
                        </div>
                      ) : (
                        <div class="more-than__slide-image">
                          <Image src={item.src} alt={item?.title ?? ""} />
                        </div>
                      )}

                      <div class="more-than__slide-title">
                        {item?.title && <p>{item.title}</p>}
                      </div>
                    </div>
                  </div>
                </div>
              );
            })
          }
        </div>
      </div>
    </div>
  </Container>
</section>

<style>
  .more-than {
    & .more-than__description {
      margin-top: var(--space20);
      font-family: var(--font-secondary), sans-serif;
      font-weight: 500;
      font-size: 16px;
      line-height: 110%;

      /* desktop */
      @media (width >= 960px) {
        margin-top: 30px;
        font-size: 24px;
      }

      /* widescreen */
      @media (width >= 1200px) {
        margin-top: var(--space32);
        font-size: 28px;
      }
    }

    & .more-than__body {
      margin-top: var(--space40);

      .swiper {
        position: relative;
        max-width: 360px;
        aspect-ratio: 360 / 640;
        border-radius: 28px;

        &::after {
          content: "";
          position: absolute;
          bottom: var(--space8);
          left: 50%;
          transform: translateX(-50%);
          width: 50%;
          height: 5px;
          border-radius: 4px;
          background-color: var(--color-text-primary);
          pointer-events: none;
          z-index: 1;
        }

        .more-than__pagination {
          --bg: rgba(255, 255, 255, 0.4);
          --bg-active: rgba(255, 255, 255, 1);

          position: absolute;
          top: 6px;
          left: 6px;
          width: calc(100% - 12px);
          z-index: 2;
          display: flex;
          gap: 3px;

          button {
            background: none;
            border: none;
            font-size: 0;
            flex-grow: 1;
            display: flex;
            align-items: center;
            padding: var(--space16) 2px;
            cursor: pointer;

            &.active span::before {
              transform: scaleX(var(--progress));
            }

            &.active ~ button {
              span::before {
                transform: scaleX(0);
              }
            }

            span {
              position: relative;
              width: 100%;
              height: 2px;
              overflow: hidden;
              background-color: var(--bg);
              border-radius: 2px;
              transition: background-color var(--transition);

              &::before {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                transform: scaleX(1);
                transform-origin: left;
                background-color: var(--bg-active);
                transition: transform var(--transition);
              }

              &::after {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background-color: var(--color-primary);
                opacity: 0;
                transition: opacity var(--transition);
              }
            }

            @media (hover: hover) {
              &:hover {
                span::after {
                  opacity: 1;
                }
              }
            }
          }
        }
      }
    }

    & .more-than__slide {
      display: flex;
      justify-content: center;

      & .more-than__slide-content {
        position: relative;
        overflow: hidden;
        cursor: grab;

        &:active {
          cursor: grabbing;
        }

        & .more-than__slide-title {
          position: absolute;
          bottom: 0;
          left: 0;
          width: 100%;
          height: auto;
          aspect-ratio: 365 / 173;
          background-image: linear-gradient(
            180deg,
            rgba(0, 0, 0, 0) 0%,
            #000000 57.87%
          );
          display: flex;
          justify-content: center;
          align-items: flex-end;
          padding: var(--space40) var(--space20);
          pointer-events: none;

          p {
            font-weight: 500;
            font-size: 16px;
            line-height: 110%;
            text-align: center;
          }
        }
      }

      & .more-than__slide-image,
      & .more-than__slide-video {
        height: 100%;

        img,
        video {
          display: block;
          width: 100%;
          height: 100%;
          object-fit: cover;
        }
      }

      & .more-than__slide-video {
        position: relative;

        button {
          position: absolute;
          top: 50%;
          left: 50%;
          border: none;
          width: 45px;
          height: 45px;
          border-radius: 50%;
          transform: translate(-50%, -50%);
          display: flex;
          justify-content: center;
          align-items: center;
          background-color: #695b61;
          cursor: pointer;
          padding-top: 2px;
          padding-right: 1px;
          transition:
            background-color var(--transition),
            color var(--transition);
          display: none;

          &:hover {
            background-color: var(--color-text-primary);
            color: var(--color-primary);
          }

          svg {
            width: 18px;
            height: auto;
          }
        }
      }
    }
  }
</style>
