---
import "../styles/_main.css";

import Head from "../components/head.astro";
import Header from "../components/header.astro";
import Footer from "../components/footer.astro";

import Hero from "../blocks/business/hero/index.astro";
import Products from "../blocks/business/products/index.astro";
import Group from "../blocks/business/group/index.astro";

import People from "../blocks/team/people/index.astro";
import Culture from "../blocks/team/culture/index.astro";
import MoreThan from "../blocks/team/more-than/index.astro";

import Useful from "../blocks/useful/index.astro";
---

<html lang="ru">
  <Head />

  <body id="top">
    <Header />

    <main class="feed">
      <section
        id="business-group"
        class="feed"
        aria-labelledby="business-title"
      >
        <Hero />
        <Products />
        <Group />
      </section>

      <section id="team" class="feed" aria-labelledby="team-title">
        <People />
        <Culture />
        <MoreThan />
      </section>

      <div class="bottom">
        <div class="bottom__bg"></div>
        <section id="useful" aria-labelledby="useful-title">
          <Useful />
        </section>

        <Footer />
      </div>
    </main>

    <script src="../scripts/_app.ts"></script>
  </body>
</html>

<style>
  body {
    background-image: linear-gradient(#01040b 75%, #0a2971 85.25%);

    /* desktop */
    @media (width >= 960px) {
      background-image: linear-gradient(180deg, #01040b 55.44%, #0a2971 85.25%);
    }
  }

  .feed {
    --section-gap: 80px;

    display: grid;
    gap: var(--section-gap);

    /* desktop */
    @media (width >= 960px) {
      --section-gap: 130px;
    }

    /* widescreen */
    @media (width >= 1200px) {
      --section-gap: 160px;
    }
  }

  .bottom {
    position: relative;
    isolation: isolate;
    padding-top: 0;

    /* tablet */
    @media (width >= 768px) {
      padding-top: 360px;
      margin-top: -360px;
    }

    /* widescreen */
    @media (width >= 1200px) {
      padding-top: 467px;
    }

    & .bottom__bg {
      position: absolute;
      overflow: hidden;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;

      &::before {
        content: "";
        position: absolute;
        z-index: -1;
        width: 200%;
        height: 85vw;
        bottom: -20%;
        left: 50%;
        transform: translate(-50%);
        background-color: #000000;
        filter: blur(30px);
        pointer-events: none;

        /* tablet */
        @media (width >= 768px) {
          height: 300px;
          filter: blur(45px);
        }

        /* desktop */
        @media (width >= 960px) {
          height: 450px;
          filter: blur(60px);
        }
      }
    }

    & > section {
      position: relative;
      z-index: 1;
    }
  }
</style>
