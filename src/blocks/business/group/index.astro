---
import Title from "../../../components/title.astro";
import Container from "../../../components/container.astro";
import card1Img from "./assets/1.webp";
import card3Img from "./assets/3.webp";
import card4Img from "./assets/4.webp";
import card5Img from "./assets/5.webp";

const cards = [
  {
    image: card1Img,
    title:
      "Трансляции в каналах MAX реализованы через интеграцию с платформой VK Видео",
  },
  {
    image: card3Img,
    title:
      "Единая панель VK Games для публикации и управления играми для ВКонтакте и ОК",
    isImageCompact: true,
  },
  {
    image: card4Img,
    title: "Интеграция новостей Дзена в ОК",
    isImageCompact: true,
  },
  {
    image: card5Img,
    title:
      "VK ID — единый сервис авторизации в OK, ВКонтакте и на других платформах",
    isImageCompact: true,
  },
];

const sliderCards = [...cards, ...cards];
---

<section class="group" aria-labelledby="group-title">
  <Container>
    <div class="group__head">
      <Title title="h3" id="group-title">
        <span class="group__title">
          Как мы усиляем друг друга внутри <span>бизнес-группы</span>
        </span>
      </Title>

      <p class="group__description" data-reveal>
        Все команды работают над своими продуктами в рамках одной
        медиастратегии. Вместе развиваем кросс-платформенные сценарии и делимся
        инфраструктурой для ускорения роста каждого продукта.
      </p>
    </div>
  </Container>

  <div class="group__slider" data-reveal>
    <div class="swiper js-group-swiper">
      <div class="swiper-wrapper">
        {
          sliderCards.map((card, index) => (
            <div
              class="swiper-slide"
              aria-hidden={index >= cards.length ? "true" : undefined}
            >
              <article class="group__card">
                <p>{card.title}</p>
                <div
                  class:list={[
                    "group__bg",
                    card.isImageCompact && "group__bg--compact",
                  ]}
                  style={`background-image: url("${card.image.src}")`}
                />
              </article>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .group {
    overflow: hidden;

    & .group__title {
      letter-spacing: -1px;

      /* desktop */
      @media (width >= 960px) {
        letter-spacing: -1.5px;
      }

      /* widescreen */
      @media (width >= 1200px) {
        letter-spacing: -2px;
      }

      span {
        white-space: nowrap;
      }
    }

    & .group__description {
      margin-top: var(--space20);
      font-family: var(--font-secondary), sans-serif;
      font-weight: 500;
      font-size: 16px;

      /* desktop */
      @media (width >= 960px) {
        margin-top: var(--space32);
        font-size: 24px;
        max-width: 85%;
      }

      /* widescreen */
      @media (width >= 1200px) {
        font-size: 28px;
      }
    }

    & .group__card {
      position: relative;
      isolation: isolate;
      overflow: hidden;
      box-shadow: 0 48px 166px 0 #00000040;
      background-color: #202020;
      display: flex;
      align-items: flex-end;
      aspect-ratio: 231 / 328;
      padding: 23px 14px 23px 18px;
      letter-spacing: -0.3px;
      border-radius: 24px;
      color: var(--color-text-primary);

      /* desktop */
      @media (width >= 960px) {
        aspect-ratio: 423 / 392;
        padding: 30px 20px 30px 24px;
        letter-spacing: -0.5px;
        border-radius: 32px;
      }

      &::before {
        content: "";
        position: absolute;
        z-index: 0;
        inset: 0;
        pointer-events: none;
        width: 90%;
        height: 90%;
        top: -40%;
        left: -40%;
        border-radius: 50%;
        background: linear-gradient(180deg, #0062ff 0%, #50337f 100%);
        filter: blur(80px);
        opacity: 0;
        transition: opacity var(--transition-long);
      }

      p {
        z-index: 2;
        max-width: 100%;
        font-size: 12px;
        line-height: 1;

        /* desktop */
        @media (width >= 960px) {
          right: var(--space24);
          bottom: var(--space24);
          left: var(--space24);
          font-size: 18px;
        }

        /* widescreen */
        @media (width >= 1200px) {
          font-size: 20px;
        }
      }
    }

    & .group__slider {
      --container-offset: var(--space16);

      margin-top: var(--space20);
      width: 100vw;

      /* tablet */
      @media (width >= 960px) {
        --container-offset: var(--space40);
      }

      /* widescreen */
      @media (width >= 1200px) {
        --container-offset: max(0px, calc((100vw - var(--container)) / 2));
      }

      .swiper {
        margin-left: var(--container-offset);
        overflow: visible;
        width: min(
          var(--container),
          calc(100vw - var(--container-offset) - var(--container-offset))
        );
      }

      /* desktop */
      @media (width >= 960px) {
        margin-top: var(--space32);
      }
    }

    & .swiper-slide {
      position: relative;
      height: auto;

      &.is-group-slide-0 {
        z-index: 4;
      }

      &.is-group-slide-1 {
        z-index: 3;

        .group__card {
          transform: translate(-5%, 7%) scale(0.86);
        }
      }

      .group__card {
        transform-origin: left top;
        transition: transform 600ms ease;
      }

      /* desktop */
      @media (width >= 960px) {
        &.is-group-slide-1 .group__card {
          transform: translate(-5%, 8%) scale(0.84);
        }

        &.is-group-slide-2 {
          z-index: 2;

          .group__card {
            transform: translate(-26%, 17%) scale(0.7);
          }
        }

        &.is-group-slide-3 {
          z-index: 1;

          .group__card {
            transform: translate(-60%, 26%) scale(0.6);
          }
        }
      }
    }

    .group__bg {
      content: "";
      position: absolute;
      z-index: 1;
      inset: 0;
      pointer-events: none;
      width: 100%;
      height: 100%;
      top: 0;
      left: 0;
      background-position: top left;
      background-repeat: no-repeat;
      background-size: 304px auto;

      /* desktop */
      @media (width >= 960px) {
        background-size: 404px auto;
      }

      &.group__bg--compact {
        background-size: 256px auto;

        /* desktop */
        @media (width >= 960px) {
          background-size: 344px auto;
        }

        /* widescreen */
        @media (width >= 1200px) {
          background-size: 368px auto;
        }
      }
    }
  }
</style>
