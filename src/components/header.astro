---
import { navigation } from "../data/navigation.ts";
import Logo from "../assets/images/logo.svg";
import MenuIcon from "../assets/images/menu.svg";
import CloseIcon from "../assets/images/x.svg";
import Container from "./container.astro";
---

<header class="header">
  <Container>
    <div class="header__content">
      <a href="#top" class="header__logo">
        <Logo />
      </a>

      <div class="header__actions">
        <button
          type="button"
          class="header__burger"
          aria-label="Открыть меню"
          aria-controls="header-nav"
          aria-expanded="false"
          data-header-burger
        >
          <MenuIcon
            class="header__burger-icon"
            aria-hidden="true"
            data-burger-icon
          />
          <CloseIcon
            class="header__burger-source"
            aria-hidden="true"
            data-burger-close-source
          />
        </button>

        <nav
          id="header-nav"
          aria-label="Основная навигация"
          class="header__nav"
        >
          <ul class="nav">
            {
              navigation.map(({ label, href }) => (
                <li>
                  <a href={`#${href}`}>{label}</a>
                </li>
              ))
            }
          </ul>
        </nav>
      </div>
    </div>
  </Container>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 20;
    background-color: var(--color-bg-main);
    box-shadow: 0 3px 58.6px 0 var(--color-primary);
    border-radius: 0 0 var(--border-radius20) var(--border-radius20);
    transition: border-radius var(--transition);

    /* desktop */
    @media (width >= 991px) {
      border-radius: 0 0 calc(2 * var(--border-radius16))
        calc(2 * var(--border-radius16));
    }

    @supports ((animation-timeline: scroll()) and (animation-range: 0 100px)) {
      box-shadow: 0 3px 58.6px 0 transparent;
      animation: header 1s linear;
      animation-timeline: scroll(root block);
      animation-range: 0 100px;
      animation-fill-mode: both;
    }

    &.is-open {
      border-radius: 0;

      /* tablet */
      @media (width >= 768px) {
        border-radius: 0 0 var(--border-radius20) var(--border-radius20);
      }
    }

    & .header__content {
      display: flex;
      justify-content: space-between;
      align-items: center;
      height: var(--header);
    }

    & .header__logo {
      font-size: 0;
      color: var(--color-text-primary);
      transition: color var(--transition);

      &:hover {
        color: var(--color-primary);
      }
    }

    & .header__actions {
      display: flex;
      align-items: center;
      justify-content: flex-end;
    }

    & .header__nav {
      position: fixed;
      top: calc(var(--header) - 1px);
      left: 0;
      width: 100%;
      height: 100dvh;
      overflow: hidden;
      background-color: var(--color-bg-main);
      transform: translate(110%);
      transition: transform var(--transition-long);
    }

    & .header__nav.is-open {
      transform: translate(0);
    }

    & .header__burger {
      display: inline-grid;
      place-items: center;
      width: 44px;
      height: 44px;
      padding: 0;
      color: var(--color-text-primary);
      background: transparent;
      border: 0;
      cursor: pointer;
      transition: color var(--transition);

      &:hover {
        color: var(--color-primary);
      }
    }

    & .header__burger-icon {
      display: block;
      width: 32px;
      height: 32px;
    }

    & .header__burger-source {
      display: none;
    }

    /* tablet */
    @media (width >= 768px) {
      & .header__actions {
        gap: var(--space32);
      }

      & .header__nav {
        position: static;
        width: auto;
        height: auto;
        overflow: visible;
        background-color: transparent;
        transform: none;
      }

      & .header__burger {
        display: none;
      }
    }
  }

  @keyframes header {
    from {
      box-shadow: 0 3px 58.6px 0 transparent;
    }

    to {
      box-shadow: 0 3px 58.6px 0 var(--color-primary);
    }
  }

  .nav {
    list-style: none;
    padding: 0 0 25vh;
    margin: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: var(--space20);
    height: 100%;

    /* tablet */
    @media (width >= 768px) {
      height: auto;
      flex-direction: row;
    }

    & a {
      font-weight: 300;
      font-size: 16px;
      line-height: 83%;
      color: var(--color-text-primary);
      transition: color var(--transition);

      &:hover {
        color: var(--color-primary);
      }
    }

    /* tablet */
    @media (width >= 768px) {
      display: flex;
      gap: var(--space32);
      padding: 0;
    }
  }
</style>
