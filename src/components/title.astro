---
interface Props {
  title?: "h1" | "h2" | "h3" | "h4" | "h5" | "h6";
  id?: string;
}

const { title = "h2", id } = Astro.props;
const TagName = title;
---

<TagName id={id} class="title"><slot /></TagName>

<style>
  .title {
    font-weight: 700;
    font-size: 24px;
    line-height: 93%;
    text-transform: lowercase;

    /* desktop */
    @media (width >= 991px) {
      font-size: 44px;
    }
  }
</style>
