---
import { Image } from "astro:assets";
import Title from "../../../components/title.astro";
import decorImg from "../../../assets/images/decor/culture.webp";
import videoPoster from "../../business/hero/assets/buisness-video-preview.webp";
import PlayButton from "../../../assets/images/play-button.svg";
import PauseButton from "../../../assets/images/pause-button.svg";
import Container from "../../../components/container.astro";
import { getVideoSrc } from "../../../utils/getVideoSrc.ts";
---

<section class="culture" aria-labelledby="culture-title">
  <Container>
    <Title title="h3" id="culture-title">
      <span class="culture__title">
        Топ-менеджеры — о&nbsp;культуре в&nbsp;команде
      </span>
      <Image
        slot="image"
        src={decorImg}
        class="title-img"
        width="145"
        height="145"
        layout="fixed"
        alt=""
        loading="lazy"
      />
    </Title>

    <div class="culture__media" data-video-player>
      <video
        class="culture__video"
        data-video-player-video
        src={getVideoSrc("hero")}
        title="Видео о культуре в команде"
        preload="metadata"
        poster={videoPoster.src}
        playsinline
      >
      </video>

      <button
        class="culture__playback"
        type="button"
        aria-label="Запустить видео"
        data-video-player-playback
      >
        <span class="culture__play-icon"><PlayButton /></span>
        <span class="culture__pause-icon"><PauseButton /></span>
      </button>
    </div>
  </Container>

  <style>
    .culture {
      /* desktop */
      @media (width >= 960px) {
        margin-top: -50px;
      }

      /* widescreen */
      @media (width >= 1200px) {
        margin-top: -70px;
      }

      & .culture__title {
        letter-spacing: -0.5px;

        /* desktop */
        @media (width >= 960px) {
          letter-spacing: -1px;
        }

        /* widescreen */
        @media (width >= 1200px) {
          letter-spacing: 0;
        }
      }

      & .title-img {
        transform-origin: right top;
        transform: rotate(-25deg) scale(0.75);

        /* desktop */
        @media (width >= 960px) {
          width: 120px;
          height: 120px;
        }

        /* widescreen */
        @media (width >= 1200px) {
          transform: rotate(-25deg) scale(1);
        }

        @media (width >= 1300px) {
          width: 145px;
          height: 145px;
          transform: rotate(-25deg) scale(1);
        }
      }

      & .culture__media {
        position: relative;
        display: grid;
        place-items: center;
        width: 100%;
        margin-top: var(--space32);
        overflow: hidden;
        border-radius: 20px;
        background-color: #071b49;
      }

      & .culture__video {
        display: block;
        width: 100%;
        height: auto;
        aspect-ratio: 1920 / 1080;
        border-radius: inherit;
        object-fit: contain;
      }

      & .culture__playback {
        position: absolute;
        inset: 0;
        display: grid;
        place-items: center;
        width: 48px;
        height: 48px;
        margin: auto;
        padding: 0;
        border: 0;
        background: transparent;
        color: var(--color-text-primary);
        cursor: pointer;
        transition:
          color var(--transition),
          opacity var(--transition);
      }

      & .culture__playback:hover {
        color: var(--color-primary);
      }

      & .culture__playback:focus-visible {
        outline: 2px solid var(--color-text-primary);
        outline-offset: 4px;
      }

      & .culture__pause-icon {
        display: none;
      }

      & .culture__media[data-playing] .culture__play-icon {
        display: none;
      }

      & .culture__media[data-playing] .culture__pause-icon {
        display: block;
      }

      @media (hover: hover) {
        &
          .culture__media[data-playing]:not(:hover)
          .culture__playback:not(:focus-visible) {
          opacity: 0;
        }
      }

      @media (width >= 960px) {
        & .culture__media {
          margin-top: var(--space44);
        }

        & .culture__playback {
          width: 72px;
          height: 82px;
        }

        & .culture__playback svg {
          width: 72px;
          height: 82px;
        }
      }
    }
  </style>
</section>
