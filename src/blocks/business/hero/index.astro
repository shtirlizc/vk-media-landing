---
import { Image } from "astro:assets";
import decorImg from "./assets/decor.webp";
import videoPoster from "./assets/buisness-video-preview.webp";
import PlayButton from "../../../assets/images/play-button.svg";
import Container from "../../../components/container.astro";
---

<section class="hero" aria-labelledby="hero">
  <Container>
    <div class="hero__copy">
      <p class="hero__eyebrow">Бизнес-группа</p>

      <h1 class="hero__title">«Социальные платформы и медиаконтент»</h1>

      <p class="hero__description">
        Мы — большая часть VK. Создаём и развиваем ключевые соцсети,
        медиасервисы и развлекательные проекты.
      </p>
    </div>
  </Container>

  <Image
    class="hero__decor"
    src={decorImg}
    width={822}
    height={459}
    widths={[288, 576, 822, 1644]}
    sizes="(min-width: 960px) 822px, 288px"
    alt=""
  />

  <Container>
    <div class="hero__media" data-video-player>
      <video
        class="hero__video"
        data-video-player-video
        src="https://storage.yandexcloud.net/team-hh-email/vk-media-landing/hero.mp4"
        title="Видео о бизнес-группе"
        preload="metadata"
        poster={videoPoster.src}
        playsinline
      >
      </video>

      <button
        class="hero__play"
        type="button"
        aria-label="Запустить видео"
        data-video-player-play
      >
        <PlayButton />
      </button>
    </div>
  </Container>
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    display: flex;
    flex-direction: column;
    align-items: center;
    overflow: hidden;
    width: 100%;
    padding-block: var(--space48) var(--space32);

    &::before {
      content: "";
      position: absolute;
      top: 160px;
      left: 50%;
      transform: translate(-50%);
      width: 19627px;
      height: 19761px;
      background: radial-gradient(
        93.7% 32.19% at 50.49% 25.96%,
        rgba(1, 56, 146, 0) 78.75%,
        #f3f8ff 79.93%,
        #f3f7ff 80.61%,
        #d7e6ff 95.9%
      );
      border: 46px solid #0162ff;
      filter: blur(60px);
    }

    & .hero__copy {
      position: relative;
      z-index: 2;
      width: 100%;
      text-align: center;
    }

    & .hero__eyebrow {
      margin-top: var(--space48);
      margin-bottom: var(--space20);
      font-size: 14px;
      line-height: 1;
    }

    & .hero__title {
      font-size: 25px;
      font-weight: 700;
      line-height: 86%;
      letter-spacing: -0.02em;
      text-transform: lowercase;
    }

    & .hero__description {
      max-width: 328px;
      margin: var(--space20) auto;
      font-size: 17px;
      line-height: 94%;
      letter-spacing: -0.025em;
    }

    & .hero__decor {
      align-self: flex-end;
      width: 288px;
      height: auto;
      transform: translateX(40px) rotate(-5deg);
    }

    & .hero__media {
      position: relative;
      z-index: 3;
      width: calc(100% - 30px);
      margin-top: -72px;
      aspect-ratio: 328 / 211;
      overflow: hidden;
      border-radius: 20px;
      clip-path: inset(0 round 20px);
      background-color: #071b49;
    }

    & .hero__video {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    & .hero__play {
      position: absolute;
      inset: 0;
      display: grid;
      place-items: center;
      width: 48px;
      height: 48px;
      margin: auto;
      padding: 0;
      border: 0;
      background: transparent;
      cursor: pointer;
      color: var(--color-text-primary);
      transition: color var(--transition);
    }

    & .hero__play:hover {
      color: var(--color-primary);
    }

    & .hero__play:focus-visible {
      outline: 2px solid var(--color-text-primary);
      outline-offset: 4px;
    }

    & .hero__media[data-playing] .hero__play {
      visibility: hidden;
    }
  }

  /* desktop */
  @media (width >= 960px) {
    .hero {
      &::before {
        top: 200px;
      }

      & .hero__eyebrow {
        margin-bottom: var(--space40);
        font-size: 24px;
      }

      & .hero__title {
        font-size: 44px;
        line-height: 93%;
      }

      & .hero__description {
        max-width: none;
        margin-top: var(--space44);
        font-size: 24px;
        line-height: 100%;
      }

      & .hero__play img {
        width: 59px;
        height: 70px;
      }

      & .hero__decor {
        width: 822px;
        transform: translateX(60px) rotate(-5deg);
      }

      & .hero__media {
        margin-top: -220px;
        width: 100%;
      }
    }
  }

  /* widescreen */
  @media (width >= 1200px) {
    .hero {
      & .hero__eyebrow {
        font-size: 26px;
      }

      & .hero__description {
        font-size: 26px;
      }

      & .hero__title {
        font-size: 60px;
      }
      & .hero__media {
        min-width: 1121px;
      }
    }
  }
</style>
