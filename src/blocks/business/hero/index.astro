---
import { Image } from "astro:assets";
import Container from "../../../components/container.astro";
import decorImg from "./assets/decor.png";
---

<div class="hero">
  <div class="hero__copy">
    <p class="hero__eyebrow">Бизнес-группа</p>

    <h1 class="hero__title" id="business-title">
      «Социальные платформы и медиаконтент»
    </h1>

    <p class="hero__description">
      Мы — большая часть VK. Создаём и развиваем ключевые соцсети, медиасервисы
      и развлекательные проекты.
    </p>
  </div>

  <Image class="hero__decor" src={decorImg} width="500" height="279" alt="" />

  <div
    class="hero__video"
    role="img"
    aria-label="Место для видео о бизнес-группе"
  >
    <span class="hero__play" aria-hidden="true">
      <svg viewBox="0 0 32 38">
        <path
          d="M31 17.27a2 2 0 0 1 0 3.46L3 36.9a2 2 0 0 1-3-1.73V2.83A2 2 0 0 1 3 .1l28 17.17Z"
        ></path>
      </svg>
    </span>
  </div>
</div>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: var(--space48) var(--space32);
    background:
      radial-gradient(
        ellipse 120% 170px at 50% 28px,
        rgb(0 98 255 / 78%) 0,
        rgb(0 98 255 / 34%) 42%,
        transparent 76%
      ),
      radial-gradient(
        ellipse 105% 220px at 50% 112px,
        rgb(0 98 255 / 92%) 0,
        rgb(0 98 255 / 48%) 31%,
        rgb(0 98 255 / 12%) 61%,
        transparent 78%
      ),
      var(--color-bg-main);

    & .hero__copy {
      position: relative;
      z-index: 2;
      text-align: center;
    }

    & .hero__eyebrow {
      margin-bottom: var(--space20);
      font-size: 14px;
      font-weight: 400;
      line-height: 1;
    }

    & .hero__title {
      font-family: var(--font-primary), sans-serif;
      font-size: 25px;
      font-weight: 700;
      line-height: 86%;
      letter-spacing: -0.02em;
      text-transform: lowercase;
    }

    & .hero__description {
      max-width: 328px;
      margin: var(--space20) auto 0;
      font-size: 17px;
      font-weight: 400;
      line-height: 94%;
      letter-spacing: -0.025em;
    }

    & .hero__decor {
      position: relative;
      z-index: 1;
      display: block;
      width: 500px;
      height: auto;
      margin-top: var(--space8);
      margin-right: -48px;
      margin-left: auto;
      pointer-events: none;
    }

    & .hero__video {
      position: relative;
      z-index: 3;
      display: grid;
      place-items: center;
      width: 100%;
      max-width: 880px;
      aspect-ratio: 328 / 211;
      margin-top: -190px;
      margin-inline: auto;
      overflow: hidden;
      border-radius: var(--border-radius12);
      background:
        radial-gradient(
          circle at 50% 49%,
          rgb(53 72 103 / 80%),
          transparent 26%
        ),
        linear-gradient(135deg, #020711 6%, #071b49 52%, #003687 100%);
    }

    & .hero__video::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(
          110deg,
          transparent 48%,
          rgb(45 118 255 / 28%) 49% 50%,
          transparent 51%
        ),
        linear-gradient(
          70deg,
          transparent 55%,
          rgb(45 118 255 / 22%) 56% 57%,
          transparent 58%
        );
    }

    & .hero__play {
      position: relative;
      z-index: 1;
      display: grid;
      place-items: center;
      width: 48px;
      height: 48px;
      color: var(--color-text-primary);
    }

    & .hero__play svg {
      display: block;
      width: 24px;
      height: 29px;
      fill: currentcolor;
    }
  }

  /* desktop */
  @media (width >= 991px) {
    .hero {
      background:
        radial-gradient(
          ellipse 88% 180px at 50% 32px,
          rgb(0 98 255 / 76%) 0,
          rgb(0 98 255 / 30%) 43%,
          transparent 78%
        ),
        radial-gradient(
          ellipse 82% 220px at 50% 132px,
          rgb(0 98 255 / 92%) 0,
          rgb(0 98 255 / 48%) 32%,
          rgb(0 98 255 / 11%) 62%,
          transparent 80%
        ),
        var(--color-bg-main);

      & .hero__eyebrow {
        margin-bottom: var(--space40);
        font-size: 16px;
      }

      & .hero__title {
        font-size: 36px;
        line-height: 83%;
      }

      & .hero__description {
        max-width: none;
        margin-top: var(--space44);
        font-size: 20px;
        line-height: 82%;
      }

      & .hero__decor {
        margin-top: var(--space20);
        margin-right: 0;
        margin-left: 50%;
      }

      & .hero__video {
        aspect-ratio: 880 / 450;
        margin-top: -110px;
        border-radius: var(--border-radius16);
      }

      & .hero__play {
        width: 72px;
        height: 72px;
      }

      & .hero__play svg {
        width: 38px;
        height: 45px;
      }
    }
  }

  /* widescreen */
  @media (width >= 1200px) {
    .hero {
      & .hero__copy,
      & .hero__video {
        max-width: var(--container);
      }

      & .hero__title {
        font-size: 44px;
      }

      & .hero__description {
        font-size: 24px;
      }

      & .hero__video {
        aspect-ratio: 1120 / 640;
      }
    }
  }
</style>
