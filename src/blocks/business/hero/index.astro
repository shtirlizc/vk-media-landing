---
import { Image } from "astro:assets";
import decorImg from "./assets/decor.png";
---

<div class="hero">
  <div class="hero__copy">
    <p class="hero__eyebrow">Бизнес-группа</p>

    <h1 class="hero__title" id="business-title">
      «Социальные платформы и медиаконтент»
    </h1>

    <p class="hero__description">
      Мы — большая часть VK. Создаём и развиваем ключевые соцсети, медиасервисы
      и развлекательные проекты.
    </p>
  </div>

  <Image class="hero__decor" src={decorImg} width="500" height="279" alt="" />

  <div
    class="hero__video"
    role="img"
    aria-label="Место для видео о бизнес-группе"
  >
    <span class="hero__play" aria-hidden="true">
      <svg viewBox="0 0 32 38">
        <path
          d="M31 17.27a2 2 0 0 1 0 3.46L3 36.9a2 2 0 0 1-3-1.73V2.83A2 2 0 0 1 3 .1l28 17.17Z"
        ></path>
      </svg>
    </span>
  </div>
</div>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: var(--space48) var(--space32);

    &::before {
      content: "";
      position: absolute;
      top: 140px;
      left: 50%;
      transform: translate(-50%);
      width: 19627px;
      height: 19761px;
      background: radial-gradient(
        93.7% 32.19% at 50.49% 25.96%,
        rgba(1, 56, 146, 0) 78.75%,
        #f3f8ff 79.93%,
        #f3f7ff 80.61%,
        #d7e6ff 95.9%
      );
      border: 46px solid #0162ff;
      filter: blur(60px);
    }

    & .hero__copy {
      position: relative;
      z-index: 2;
      text-align: center;
    }

    & .hero__eyebrow {
      margin-bottom: var(--space20);
      font-size: 14px;
      font-weight: 400;
      line-height: 1;
    }

    & .hero__title {
      font-family: var(--font-primary), sans-serif;
      font-size: 25px;
      font-weight: 700;
      line-height: 86%;
      letter-spacing: -0.02em;
      text-transform: lowercase;
    }

    & .hero__description {
      max-width: 328px;
      margin: var(--space20) auto 0;
      font-size: 17px;
      font-weight: 400;
      line-height: 94%;
      letter-spacing: -0.025em;
    }

    & .hero__decor {
      position: relative;
      z-index: 1;
      display: block;
      width: 500px;
      height: auto;
      margin-top: var(--space8);
      margin-right: -48px;
      margin-left: auto;
      pointer-events: none;
    }

    & .hero__video {
      position: relative;
      z-index: 3;
      display: grid;
      place-items: center;
      width: 100%;
      max-width: 880px;
      aspect-ratio: 328 / 211;
      margin-top: -190px;
      margin-inline: auto;
      overflow: hidden;
      border-radius: var(--border-radius12);
    }

    & .hero__video::before {
      content: "";
      position: absolute;
      inset: 0;
    }

    & .hero__play {
      position: relative;
      z-index: 1;
      display: grid;
      place-items: center;
      width: 48px;
      height: 48px;
      color: var(--color-text-primary);
    }

    & .hero__play svg {
      display: block;
      width: 24px;
      height: 29px;
      fill: currentcolor;
    }
  }

  /* desktop */
  @media (width >= 991px) {
    .hero {
      & .hero__eyebrow {
        margin-bottom: var(--space40);
        font-size: 16px;
      }

      & .hero__title {
        font-size: 36px;
        line-height: 83%;
      }

      & .hero__description {
        max-width: none;
        margin-top: var(--space44);
        font-size: 20px;
        line-height: 82%;
      }

      & .hero__decor {
        margin-top: var(--space20);
        margin-right: 0;
        margin-left: 50%;
      }

      & .hero__video {
        aspect-ratio: 880 / 450;
        margin-top: -110px;
        border-radius: var(--border-radius16);
      }

      & .hero__play {
        width: 72px;
        height: 72px;
      }

      & .hero__play svg {
        width: 38px;
        height: 45px;
      }
    }
  }

  /* widescreen */
  @media (width >= 1200px) {
    .hero {
      & .hero__copy,
      & .hero__video {
        max-width: var(--container);
      }

      & .hero__title {
        font-size: 44px;
      }

      & .hero__description {
        font-size: 24px;
      }

      & .hero__video {
        aspect-ratio: 1120 / 640;
      }
    }
  }
</style>
